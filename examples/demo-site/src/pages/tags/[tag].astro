---
import { getCollection } from "astro:content"
import { buildPostMeta, breadcrumbSchema } from "@shipwreck/blog-core"
import PostCard from "@shipwreck/blog-core/components/PostCard.astro"
import Breadcrumbs from "@shipwreck/blog-core/components/Breadcrumbs.astro"
import BaseLayout from "../../layouts/BaseLayout.astro"
import siteConfig from "../../../site.config"

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => data.status === "published")
  const tags = new Set<string>()
  for (const p of posts) for (const t of p.data.tags ?? []) tags.add(t.toLowerCase())
  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => (p.data.tags ?? []).map((t) => t.toLowerCase()).includes(tag))
        .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()),
    },
  }))
}

const { tag, posts } = Astro.props
const url = new URL(`${siteConfig.blogBasePath}/tags/${tag}/`, siteConfig.baseUrl).toString()
const blogUrl = new URL(siteConfig.blogBasePath, siteConfig.baseUrl).toString()

const meta = buildPostMeta({
  post: {
    title: `Posts tagged "${tag}" — ${siteConfig.siteName}`,
    metaDescription: `All posts tagged "${tag}" on ${siteConfig.siteName}`,
    publishDate: new Date(),
    status: "published",
    tags: [],
    noindex: false,
    featured: false,
    sticky: false,
    articleType: "BlogPosting",
  },
  siteConfig,
  url,
})

const crumbs = [
  { name: "Home", url: siteConfig.baseUrl },
  { name: "Blog", url: blogUrl },
  { name: `#${tag}` },
]
---

<BaseLayout
  meta={{ ...meta, og: { ...meta.og, type: "website" } }}
  jsonLd={breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: c.url ?? url })))}
>
  <div class="mx-auto max-w-3xl">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 font-heading text-4xl font-bold text-primary">#{tag}</h1>
    <p class="mt-2 text-muted">{posts.length} {posts.length === 1 ? "post" : "posts"}</p>
    <div class="mt-8 space-y-6">
      {posts.map((post) => (
        <PostCard
          post={post}
          basePath={siteConfig.blogBasePath}
          defaultImage={siteConfig.seo.defaultFeaturedImage}
        />
      ))}
    </div>
  </div>
</BaseLayout>
