---
import { getCollection } from "astro:content"
import { prepareCategoryPage } from "@shipwreck/blog-core"
import ListingPage from "@shipwreck/blog-core/pages/ListingPage.astro"
import BaseLayout from "../../layouts/BaseLayout.astro"
import siteConfig from "../../../site.config"

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => data.status === "published")
  const cats = new Set<string>()
  for (const p of posts) if (p.data.category) cats.add(p.data.category.toLowerCase())
  return Array.from(cats).map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts
        .filter((p) => p.data.category?.toLowerCase() === category)
        .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()),
    },
  }))
}

const { category, posts } = Astro.props
const data = prepareCategoryPage({ category, posts, siteConfig })
---

<BaseLayout meta={data.meta} jsonLd={data.jsonLd}>
  <ListingPage data={data} siteConfig={siteConfig} />
</BaseLayout>
