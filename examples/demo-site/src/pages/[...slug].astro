---
import { getCollection, getEntry, render } from "astro:content"
import {
  buildPostMeta,
  articleSchema,
  breadcrumbSchema,
  faqSchema,
  rankRelatedPosts,
  readingTimeLabel,
  getPostAuthorIds,
  type ArticleAuthor,
} from "@shipwreck/blog-core"
import ArticleLayout from "@shipwreck/blog-core/components/ArticleLayout.astro"
import Breadcrumbs from "@shipwreck/blog-core/components/Breadcrumbs.astro"
import TableOfContents from "@shipwreck/blog-core/components/TableOfContents.astro"
import RelatedPosts from "@shipwreck/blog-core/components/RelatedPosts.astro"
import AuthorBio from "@shipwreck/blog-core/components/AuthorBio.astro"
import AuthorAvatar from "@shipwreck/blog-core/components/AuthorAvatar.astro"
import TagList from "@shipwreck/blog-core/components/TagList.astro"
import CTABlock from "@shipwreck/blog-core/components/CTABlock.astro"
import BaseLayout from "../layouts/BaseLayout.astro"
import siteConfig from "../../site.config"
import { ctaRegistry } from "../components/cta/registry"

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => data.status === "published")
  return posts.map((post) => ({ params: { slug: post.id }, props: { post, all: posts } }))
}

const { post, all } = Astro.props
const { Content, headings, remarkPluginFrontmatter } = await render(post)

const url = new URL(`${siteConfig.blogBasePath}/${post.id}/`, siteConfig.baseUrl).toString()
const blogUrl = new URL(siteConfig.blogBasePath, siteConfig.baseUrl).toString()
const meta = buildPostMeta({ post: post.data, siteConfig, url })

const authorIds = getPostAuthorIds(post.data)
const authorEntries = await Promise.all(authorIds.map((id) => getEntry("authors", id)))
const validAuthors = authorEntries.filter((e): e is NonNullable<typeof e> => Boolean(e))

const articleAuthors: ArticleAuthor[] = validAuthors.map(({ data: a }) => ({
  name: a.name,
  ...(a.url ? { url: a.url } : {}),
}))

const jsonLd: object[] = [
  articleSchema({ post: post.data, siteConfig, url, authors: articleAuthors }),
  breadcrumbSchema([
    { name: "Home", url: siteConfig.baseUrl },
    { name: "Blog", url: blogUrl },
    { name: post.data.title, url },
  ]),
]

if (post.data.faqItems && post.data.faqItems.length > 0) {
  jsonLd.push(faqSchema(post.data.faqItems))
}

const related = siteConfig.layout.showRelatedPosts
  ? rankRelatedPosts({
      current: post,
      candidates: all,
      limit: siteConfig.layout.relatedPostsCount,
    })
  : []

// Featured posts for the bottom grid — exclude current, prefer featured: true,
// fall back to recency so the grid isn't empty on a fresh site.
const featuredCandidates = all
  .filter((p) => p.id !== post.id && p.data.status === "published")
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
const featured = featuredCandidates.filter((p) => p.data.featured)
const bottomGridPosts = (related.length > 0 ? related : (featured.length > 0 ? featured : featuredCandidates)).slice(0, 3)

const crumbs = [
  { name: "Home", url: siteConfig.baseUrl },
  { name: "Blog", url: blogUrl },
  { name: post.data.title },
]

const wordCount = (remarkPluginFrontmatter as { wordCount?: number } | undefined)?.wordCount
const readingLabel = wordCount ? readingTimeLabel("x ".repeat(wordCount)) : undefined

// Only render an in-page hero when the post explicitly sets one.
// We deliberately do NOT fall back to siteConfig.seo.defaultFeaturedImage —
// that's the OG image (brand banner), which looks wrong as an article hero.
const heroImage = post.data.featuredImage
---

<BaseLayout meta={meta} jsonLd={jsonLd}>
  <div class="mx-auto max-w-7xl">
    <Breadcrumbs items={crumbs} />

    <ArticleLayout>
      {siteConfig.layout.showTableOfContents && (
        <TableOfContents slot="toc" headings={headings} sticky maxDepth={4} title="Table of contents" />
      )}

      <aside slot="aside" class="space-y-6 lg:sticky lg:top-24">
        <CTABlock
          siteConfig={siteConfig}
          category={post.data.category}
          postOverride={post.data.ctaBlock}
          registry={ctaRegistry}
        />
      </aside>

      <article>
        <header class="not-prose mb-8">
          <h1 class="font-heading text-4xl font-bold text-primary md:text-5xl">{post.data.title}</h1>
          {siteConfig.layout.showAuthor && validAuthors.length > 0 && (
            <div class="mt-5 flex items-center gap-3">
              <div class="flex -space-x-2">
                {validAuthors.map(({ data: a }) => (
                  <AuthorAvatar
                    author={a}
                    size={40}
                    fallbackImage={siteConfig.seo.defaultAuthorAvatar}
                    class="ring-2 ring-bg"
                  />
                ))}
              </div>
              <div class="text-sm">
                <p class="text-text">
                  {validAuthors.map(({ id, data: a }, i) => (
                    <>
                      {i > 0 && <span class="text-muted/60"> &amp; </span>}
                      <a
                        href={`${siteConfig.blogBasePath}/authors/${id}/`}
                        class="font-semibold hover:text-accent"
                      >
                        {a.name}
                      </a>
                    </>
                  ))}
                </p>
                <p class="text-muted">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString("en-AU", { year: "numeric", month: "long", day: "numeric" })}
                  </time>
                  {siteConfig.layout.showReadingTime && readingLabel && (
                    <> · {readingLabel}</>
                  )}
                </p>
              </div>
            </div>
          )}
          {(!siteConfig.layout.showAuthor || validAuthors.length === 0) && (
            <p class="mt-4 text-sm text-muted">
              <time datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString("en-AU", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              {siteConfig.layout.showReadingTime && readingLabel && (
                <> · {readingLabel}</>
              )}
            </p>
          )}
          {post.data.excerpt && <p class="mt-4 text-lg text-muted">{post.data.excerpt}</p>}
          {heroImage && (
            <img
              src={heroImage}
              alt={post.data.featuredImageAlt ?? post.data.title}
              class="mt-8 aspect-[16/9] w-full rounded-card object-cover"
            />
          )}
        </header>

        <div class="prose prose-lg max-w-none">
          <Content />
        </div>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="mt-10 border-t border-border pt-6">
            <TagList tags={post.data.tags} basePath={siteConfig.blogBasePath} />
          </div>
        )}

        {validAuthors.map(({ id, data: author }) => (
          <AuthorBio
            author={author}
            href={`${siteConfig.blogBasePath}/authors/${id}/`}
            fallbackImage={siteConfig.seo.defaultAuthorAvatar}
          />
        ))}
      </article>

      <RelatedPosts
        posts={bottomGridPosts}
        basePath={siteConfig.blogBasePath}
        title="More articles"
        layout="grid"
      />
    </ArticleLayout>
  </div>
</BaseLayout>
