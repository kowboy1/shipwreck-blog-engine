---
import siteConfig from "../../../site.config"
---

<aside class="rounded-card border border-primary bg-bg p-6">
  <h3 class="font-heading text-xl font-semibold text-primary">Get a free SEO audit</h3>
  <p class="mt-2 text-muted">{siteConfig.brand.organizationName} will review your site and send a 1-page action plan.</p>
  <a
    href="/audit"
    class="mt-4 inline-block rounded-card bg-primary px-5 py-2 font-medium text-bg hover:opacity-90"
  >
    Request audit
  </a>
</aside>
