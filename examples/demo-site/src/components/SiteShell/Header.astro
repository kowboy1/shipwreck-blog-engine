---
// SiteShell/Header.astro
// Replace this with the host site's header markup when theming.
// Keep classes intact — Tailwind config will be aligned to match.
import siteConfig from "../../../site.config"
---

<header class="border-b border-border bg-bg">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
    <a href="/" class="font-heading text-xl font-bold text-primary">
      {siteConfig.siteName}
    </a>
    <nav class="flex gap-6 text-sm">
      <a href="/" class="text-text hover:text-accent">Home</a>
      <a href={siteConfig.blogBasePath} class="text-text hover:text-accent">Blog</a>
    </nav>
  </div>
</header>
