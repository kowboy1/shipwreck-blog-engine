---
/**
 * Three-column article layout:
 *
 *   [ ToC (sticky) ] [ Article body ] [ Featured posts (sticky) ]
 *
 * On mobile: stacked. ToC moves above the article (collapsible).
 *
 * Pages render their content into the named slots:
 *   <slot name="toc" />        — left column (typically <TableOfContents>)
 *   <slot />                   — main column (article header + Content)
 *   <slot name="aside" />      — right column (typically <FeaturedPosts>)
 *
 * If a slot is empty, that column collapses gracefully.
 */
const hasToc = Astro.slots.has("toc")
const hasAside = Astro.slots.has("aside")
---

<div class="article-layout">
  {hasToc && (
    <div class="article-layout__toc">
      <details class="lg:hidden" open>
        <summary class="cursor-pointer rounded-card border border-border bg-bg/60 p-4 text-sm font-semibold text-primary">
          On this page
        </summary>
        <div class="mt-3">
          <slot name="toc" />
        </div>
      </details>
      <div class="hidden lg:block">
        <slot name="toc" />
      </div>
    </div>
  )}

  <div class="article-layout__main">
    <slot />
  </div>

  {hasAside && (
    <div class="article-layout__aside">
      <slot name="aside" />
    </div>
  )}
</div>

<style>
  .article-layout {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    grid-template-areas:
      "toc"
      "main"
      "aside";
  }

  .article-layout__toc { grid-area: toc; }
  .article-layout__main { grid-area: main; min-width: 0; }
  .article-layout__aside { grid-area: aside; }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: 240px minmax(0, 1fr) 280px;
      grid-template-areas: "toc main aside";
      gap: 3rem;
    }
  }

  /* When only ToC is present (no aside): two columns */
  .article-layout:not(:has(.article-layout__aside)) {
    @media (min-width: 1024px) {
      grid-template-columns: 240px minmax(0, 1fr);
      grid-template-areas: "toc main";
    }
  }

  /* When only aside is present (no ToC): two columns the other way */
  .article-layout:not(:has(.article-layout__toc)) {
    @media (min-width: 1024px) {
      grid-template-columns: minmax(0, 1fr) 280px;
      grid-template-areas: "main aside";
    }
  }
</style>
