---
/**
 * Compact "Popular articles" sidebar widget for post pages.
 *
 * Renders a stacked list of mini cards — small horizontal thumbnail + title +
 * date. Designed for the ~280px right column of ArticleLayout. Five cards
 * fit comfortably; tune limit via siteConfig.sidebar.popular.limit.
 *
 * Data source is chosen upstream (manual override > popularity.json > recency
 * fallback) — see preparePostPageData + utils/popularity.ts.
 */
import type { Post } from "../schemas/post.js"

interface PostEntry {
  id: string
  data: Post
}

interface Props {
  posts: PostEntry[]
  basePath: string
  heading: string
  /** Fallback image used when a listed post has no featuredImage. */
  fallbackImage?: string
  /**
   * Informational badge text — e.g. "30-day". Only rendered when set, and
   * only when the data came from a popularity file. preparePostPageData
   * decides whether to pass this.
   */
  windowLabel?: string
}

const { posts, basePath, heading, fallbackImage, windowLabel } = Astro.props
const base = basePath.replace(/\/$/, "")

if (posts.length === 0) return Astro.response
---

<aside class="popular-posts not-prose rounded-card border border-border bg-bg-elevated p-4 shadow-card">
  <header class="flex items-baseline justify-between gap-2">
    <h3 class="font-heading text-sm font-bold uppercase tracking-wide text-primary">
      {heading}
    </h3>
    {windowLabel && (
      <span class="text-[10px] uppercase tracking-wider text-muted/70">{windowLabel}</span>
    )}
  </header>

  <ol class="mt-3 space-y-1.5">
    {posts.map((post, i) => {
      const href = `${base}/${post.id}/`
      const image = post.data.featuredImage ?? fallbackImage
      const altText = post.data.featuredImageAlt ?? (post.data.featuredImage ? post.data.title : "")
      return (
        <li>
          <a
            href={href}
            class="group flex items-start gap-3 rounded-sm p-1.5 transition-colors hover:bg-bg/40"
          >
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-bg/60 text-[11px] font-bold text-muted group-hover:bg-accent/15 group-hover:text-accent">
              {i + 1}
            </span>
            {image && (
              <img
                src={image}
                alt={altText}
                aria-hidden={post.data.featuredImage ? undefined : "true"}
                width="48"
                height="48"
                loading="lazy"
                decoding="async"
                class="h-12 w-12 shrink-0 rounded-sm object-cover"
              />
            )}
            <span class="min-w-0 flex-1">
              <span class="line-clamp-2 text-sm font-semibold leading-snug text-primary group-hover:text-accent">
                {post.data.title}
              </span>
              <span class="mt-1 block text-xs text-muted">
                <time datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString("en-AU", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </span>
            </span>
          </a>
        </li>
      )
    })}
  </ol>
</aside>
