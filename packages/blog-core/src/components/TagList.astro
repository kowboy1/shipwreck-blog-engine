---
interface Props {
  tags: string[]
  basePath: string
}

const { tags, basePath } = Astro.props
const base = basePath.replace(/\/$/, "")
---

{tags.length > 0 && (
  <ul class="flex flex-wrap gap-2 text-sm">
    {tags.map((tag) => (
      <li>
        <a
          href={`${base}/tags/${encodeURIComponent(tag.toLowerCase())}/`}
          class="rounded-card border border-border px-3 py-1 text-muted hover:border-accent hover:text-accent"
        >
          #{tag}
        </a>
      </li>
    ))}
  </ul>
)}
