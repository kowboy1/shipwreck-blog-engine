---
interface Props {
  tags: string[]
  basePath: string
}

const { tags, basePath } = Astro.props
const base = basePath.replace(/\/$/, "")
---

{tags.length > 0 && (
  <ul class="not-prose flex flex-wrap gap-2 text-xs">
    {tags.map((tag) => (
      <li>
        <a
          href={`${base}/tags/${encodeURIComponent(tag.toLowerCase())}/`}
          class="inline-flex items-center rounded-full border border-border bg-bg/40 px-3 py-1 font-medium uppercase tracking-wide text-muted transition hover:border-accent hover:bg-accent/10 hover:text-accent"
        >
          {tag}
        </a>
      </li>
    ))}
  </ul>
)}
