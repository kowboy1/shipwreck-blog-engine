---
import type { AuthorRecord } from "../schemas/author.js"

interface Props {
  author: AuthorRecord
}

const { author } = Astro.props
---

<aside class="mt-12 flex gap-4 rounded-card border border-border bg-bg p-6">
  {author.avatar && (
    <img
      src={author.avatar}
      alt={author.name}
      class="h-16 w-16 flex-none rounded-full object-cover"
      loading="lazy"
    />
  )}
  <div class="min-w-0">
    <p class="font-heading text-lg font-semibold text-primary">{author.name}</p>
    {author.bio && <p class="mt-1 text-sm text-muted">{author.bio}</p>}
    <div class="mt-2 flex gap-3 text-sm">
      {author.url && <a href={author.url} class="text-accent hover:underline">Website</a>}
      {author.twitter && (
        <a href={`https://twitter.com/${author.twitter.replace("@", "")}`} class="text-accent hover:underline">
          Twitter
        </a>
      )}
      {author.linkedin && <a href={author.linkedin} class="text-accent hover:underline">LinkedIn</a>}
    </div>
  </div>
</aside>
