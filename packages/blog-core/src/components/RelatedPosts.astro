---
import type { Post } from "../schemas/post.js"
import PostCard from "./PostCard.astro"

interface Props {
  posts: Array<{ id: string; data: Post }>
  basePath: string
  title?: string
  /** "grid" = 3-up horizontal at md+ (default). "stack" = vertical stack. */
  layout?: "grid" | "stack"
}

const {
  posts,
  basePath,
  title = "Related articles",
  layout = "grid",
} = Astro.props
---

{posts.length > 0 && (
  <section class="mt-16 border-t border-border pt-10">
    <h2 class="mb-8 font-heading text-2xl font-semibold text-primary">{title}</h2>
    <div
      class:list={[
        layout === "grid"
          ? "grid grid-cols-1 gap-6 md:grid-cols-3"
          : "space-y-6",
      ]}
    >
      {posts.map((post) => (
        <PostCard post={post} basePath={basePath} />
      ))}
    </div>
  </section>
)}
